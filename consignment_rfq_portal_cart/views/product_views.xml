<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_rfq_portal" model="ir.ui.view">
        <field name="name">product.template.form.rfq.portal</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='purchase_ok']" position="after">
                <field name="x_rfq_portal_ok"/>
            </xpath>
        </field>
    </record>
</odoo>
